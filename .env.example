PROJECT_NAME=QuantForge
VERSION=0.1
ENVIRONMENT=dev
PRIMARY_EXCHANGE=bybit
SYMBOLS=BTCUSDT
COLLECTOR_INTERVAL=1
QUEUE_MAX_SIZE=10
DATABASE_URL=sqlite:///QuantForge.db
REDIS_URL=redis://localhost:6379/0
LOG_LEVEL=INFO
OLLAMA_URL=http://localhost:11434
BYBIT_WS=wss://stream.bybit.com/v5/public/linear

# AI Runtime Settings
AI_PROVIDER=ollama
# AI_MODEL must be configured explicitly (e.g., llama3, mistral, etc.)
AI_MODEL=
AI_BASE_URL=http://localhost:11434
AI_CONNECTION_TIMEOUT_SECONDS=5.0
AI_INFERENCE_TIMEOUT_SECONDS=30.0
AI_STRUCTURED_MAX_RETRIES=3
